#!/bin/bash
set -u

LOG="/var/tmp/lbp2900-lbp3000-patcher.log"
exec >>"$LOG" 2>&1

echo "==== $(date) Canon LBP2900 LBP3000 patcher postinstall ===="

FILTER="/usr/libexec/cups/filter/rastertocapt"
FALLBACK_PPD="/Library/Printers/PPDs/Contents/Resources/CanonLBP2900-open-capt.ppd"
CLONED_PPD="/Library/Printers/PPDs/Contents/Resources/CanonLBP2900-from-LBP3000.ppd"
QUEUE="Canon_LBP2900"
BASE_QUEUE="Canon_LBP3000"
BASE_QUEUE_PPD="/etc/cups/ppd/Canon_LBP3000.ppd"
BASE_RESOURCE_PPD_GZ="/Library/Printers/PPDs/Contents/Resources/CNMC2LBP3000AUK.ppd.gz"
STATUS_MONITOR="/Library/Printers/Canon/CUPSCAPT2/StatusMonitor/StatusMonitor.app"
STATUS_MONITOR_ID="jp.co.canon.CUPSCAPT2.StatusMonitor"
CAPT_ROOT="/Library/Printers/Canon/CUPSCAPT2"
BACKGROUND_AGENT="/Library/LaunchAgents/jp.co.canon.CUPSCAPT2.BG.plist"
BACKGROUND_AGENT_DISABLED="/Library/LaunchAgents/jp.co.canon.CUPSCAPT2.BG.plist.disabled-by-lbp2900-patcher"
BACKGROUND_LABEL="jp.co.canon.CUPSCAPT2.BackGrounder"
BACKGROUND_PROCESS="Canon CAPT BackGrounder"

/usr/bin/find /usr/libexec/cups -name '._*' -delete 2>/dev/null || true
/usr/bin/find /Library/Printers -name '._*' -delete 2>/dev/null || true

/usr/sbin/chown root:wheel "$FILTER"
/bin/chmod 0555 "$FILTER"
/usr/sbin/chown root:wheel "$FALLBACK_PPD"
/bin/chmod 0644 "$FALLBACK_PPD"

TMP_PPD="$(/usr/bin/mktemp -t CanonLBP2900-from-LBP3000.XXXXXX)"
if [ -f "$BASE_QUEUE_PPD" ]; then
  echo "Cloning PPD from existing queue: $BASE_QUEUE_PPD"
  /bin/cp "$BASE_QUEUE_PPD" "$TMP_PPD"
elif [ -f "$BASE_RESOURCE_PPD_GZ" ]; then
  echo "Cloning PPD from Canon LBP3000 driver resource: $BASE_RESOURCE_PPD_GZ"
  /usr/bin/gunzip -c "$BASE_RESOURCE_PPD_GZ" >"$TMP_PPD"
else
  echo "Error: Canon LBP3000 PPD was not found. Install Canon's original LBP3000/CAPT driver first, then run this patcher."
  /bin/rm -f "$TMP_PPD"
  exit 1
fi

/usr/bin/perl -0pi -e '
  s/^\*PCFileName:.*$/\*PCFileName: "CNL290AK.PPD"/mg;
  s/^\*Product:.*$/\*Product: "\(lbp2900 a\)"/mg;
  s/^\*ModelName:.*$/\*ModelName: "Canon LBP2900 CAPT"/mg;
  s/^\*ShortNickName:.*$/\*ShortNickName: "LBP2900"/mg;
  s/^\*NickName:.*$/\*NickName: "Canon LBP2900 CAPT \(cloned from LBP3000\)"/mg;
  s{^\*cupsFilter:.*$}{\*cupsFilter: "application/vnd.cups-raster 1 rastertocapt"}mg;
  s/^\*CNPrinterName:.*$/\*CNPrinterName: "Canon LBP2900"/mg;
  s/^\*%CNUIValue: \*CNUIModelName\(LBP3000\):False$/\*%CNUIValue: \*CNUIModelName\(LBP2900\):False/mg;
' "$TMP_PPD"

ensure_ppd_line() {
  key="$1"
  line="$2"
  if ! /usr/bin/grep -q "^\*$key:" "$TMP_PPD"; then
    /bin/echo "$line" >>"$TMP_PPD"
  fi
}

ensure_ppd_line "opbidiPlugin" '*opbidiPlugin: "captmoncnab3"'
ensure_ppd_line "opbidiReadInterval" '*opbidiReadInterval: "2"'
ensure_ppd_line "ccpdReady" '*ccpdReady: "True"'
ensure_ppd_line "APPrinterUtilityPath" '*APPrinterUtilityPath: "/Library/Printers/Canon/CUPSCAPT2/StatusMonitor/StatusMonitor.app"'
ensure_ppd_line "APPrinterIconPath" '*APPrinterIconPath: "/Library/Printers/Canon/CUPSCAPT2/Icons/CAPT.icns"'
ensure_ppd_line "CNPrinterName" '*CNPrinterName: "Canon LBP2900"'
ensure_ppd_line "CNDriverRootPath" '*CNDriverRootPath: "/Library/Printers/Canon/CUPSCAPT2"'
ensure_ppd_line "CNPDLType" '*CNPDLType: "CAPT"'
ensure_ppd_line "CNColorMode" '*CNColorMode: "mono"'
ensure_ppd_line "CNBidiModeUSB" '*CNBidiModeUSB: "Both_Di"'

/bin/mv "$TMP_PPD" "$CLONED_PPD"
/usr/sbin/chown root:wheel "$CLONED_PPD"
/bin/chmod 0644 "$CLONED_PPD"
echo "Saved LBP3000-derived reference PPD: $CLONED_PPD"

if [ -d "$STATUS_MONITOR" ]; then
  echo "Detected Canon CAPT StatusMonitor from the original driver."
else
  echo "Warning: Canon CAPT StatusMonitor was not found. Printing can still work, but install Canon's LBP3000/CAPT driver first if you need StatusMonitor."
fi

MISSING_CAPT_RUNTIME=0
for path in \
  "$CAPT_ROOT/Bidi/captemon" \
  "$CAPT_ROOT/Bins" \
  "$CAPT_ROOT/Libs" \
  "$CAPT_ROOT/Recipe" \
  "$CAPT_ROOT/PDEs"; do
  if [ ! -e "$path" ]; then
    echo "Warning: missing Canon CAPT runtime path: $path"
    MISSING_CAPT_RUNTIME=1
  fi
done
if [ "$MISSING_CAPT_RUNTIME" = "1" ]; then
  echo "Warning: StatusMonitor may open without a status window until Canon's original CAPT runtime is reinstalled."
fi

CURRENT_USER="$(/usr/bin/stat -f %Su /dev/console 2>/dev/null || true)"
CURRENT_UID="$(/usr/bin/stat -f %u /dev/console 2>/dev/null || echo 0)"
if [ -n "$CURRENT_USER" ] && [ "$CURRENT_USER" != "root" ] && [ "$CURRENT_UID" != "0" ]; then
  if [ -f "$BACKGROUND_AGENT" ]; then
    /bin/launchctl disable "gui/$CURRENT_UID/$BACKGROUND_LABEL" 2>/dev/null || true
    /bin/launchctl bootout "gui/$CURRENT_UID" "$BACKGROUND_AGENT" 2>/dev/null || true
    /bin/mv "$BACKGROUND_AGENT" "$BACKGROUND_AGENT_DISABLED" 2>/dev/null || true
    echo "Disabled Canon CAPT BackGrounder for $CURRENT_USER to keep the patched queue on usb:// after reboot."
  elif [ -f "$BACKGROUND_AGENT_DISABLED" ]; then
    echo "Canon CAPT BackGrounder LaunchAgent is already disabled by the LBP2900 patcher."
  fi
  USER_HOME="$(/usr/bin/dscl . -read "/Users/$CURRENT_USER" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}')"
  if [ -n "$USER_HOME" ]; then
    /bin/launchctl asuser "$CURRENT_UID" /usr/bin/sudo -u "$CURRENT_USER" /usr/bin/defaults delete "$STATUS_MONITOR_ID" SUIWindowHeight 2>/dev/null || true
    /bin/launchctl asuser "$CURRENT_UID" /usr/bin/sudo -u "$CURRENT_USER" /usr/bin/defaults delete "$STATUS_MONITOR_ID" SUIWindowOriginX 2>/dev/null || true
    /bin/launchctl asuser "$CURRENT_UID" /usr/bin/sudo -u "$CURRENT_USER" /usr/bin/defaults delete "$STATUS_MONITOR_ID" SUIWindowOriginY 2>/dev/null || true
    /bin/launchctl asuser "$CURRENT_UID" /usr/bin/sudo -u "$CURRENT_USER" /usr/bin/defaults delete "$STATUS_MONITOR_ID" SUIWindowWidth 2>/dev/null || true
    /bin/launchctl asuser "$CURRENT_UID" /usr/bin/sudo -u "$CURRENT_USER" /usr/bin/defaults write "$STATUS_MONITOR_ID" NSQuitAlwaysKeepsWindows -bool false 2>/dev/null || true
    /bin/launchctl asuser "$CURRENT_UID" /usr/bin/sudo -u "$CURRENT_USER" /usr/bin/defaults write "$STATUS_MONITOR_ID" SUICurrentPrinter -string "$QUEUE" 2>/dev/null || true
    /bin/rm -rf "$USER_HOME/Library/Saved Application State/$STATUS_MONITOR_ID.savedState"
    echo "Reset StatusMonitor persistent UI state for $CURRENT_USER."
  fi
fi
/usr/bin/pkill -f "$BACKGROUND_PROCESS" 2>/dev/null || true

BASE_URI="$(/usr/bin/lpstat -v "$BASE_QUEUE" 2>/dev/null | /usr/bin/awk -F': ' 'NR == 1 {print $2; exit}')"
USB_URI=""
if [ -n "$BASE_URI" ]; then
  echo "Detected device URI from $BASE_QUEUE: $BASE_URI"
  case "$BASE_URI" in
    usb://*)
      USB_URI="$BASE_URI"
      ;;
    cnbma2://*/usbSP/*)
      USB_PATH="${BASE_URI#*/usbSP/}"
      USB_URI="usb://$USB_PATH"
      echo "Converted Canon cnbma2 URI to CUPS USB URI: $USB_URI"
      ;;
    *)
      echo "Not reusing non-USB Canon backend URI for rastertocapt: $BASE_URI"
      ;;
  esac
fi
if [ -z "$USB_URI" ]; then
  USB_URI="$(/usr/sbin/lpinfo -v 2>/dev/null | /usr/bin/awk 'index($2, "usb://Canon/LBP2900") == 1 {print $2; exit}')"
fi
if [ -z "$USB_URI" ]; then
  USB_URI="$(/usr/sbin/lpinfo -v 2>/dev/null | /usr/bin/awk 'index($2, "usb://Canon/") == 1 && index($2, "LBP") > 0 {print $2; exit}')"
fi
if [ -z "$USB_URI" ]; then
  USB_URI="usb://Canon/LBP2900"
fi

echo "Using USB URI: $USB_URI"

echo "Creating $QUEUE with the open CAPT raster PPD. The cloned LBP3000 PPD is kept only as a reference because it blocks the rastertocapt print path on macOS 27."
/usr/sbin/lpadmin -p "$QUEUE" -E -v "$USB_URI" -P "$FALLBACK_PPD" -D "Canon LBP2900 CAPT"
/usr/bin/lpoptions -p "$QUEUE" -o PageSize=A4 >/dev/null 2>&1 || true
/usr/bin/lpoptions -d "$QUEUE" >/dev/null 2>&1 || true
/usr/sbin/cupsenable "$QUEUE" 2>/dev/null || true
/usr/sbin/cupsaccept "$QUEUE" 2>/dev/null || true

echo "Installed patched queue:"
/usr/bin/lpstat -v "$QUEUE" 2>/dev/null || true
/usr/bin/lpstat -p "$QUEUE" -l 2>/dev/null || true
/bin/ls -l "$FILTER" "$CLONED_PPD" "$FALLBACK_PPD" 2>/dev/null || true
echo "==== done ===="

exit 0
